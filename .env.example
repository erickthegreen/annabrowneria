# ╔══════════════════════════════════════════════════════════════╗
# ║          AnnaBrowneria — Variáveis de Ambiente               ║
# ║  Copie este arquivo para .env e preencha com seus valores    ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Supabase (Etapas 2 e 3) ──────────────────────────────────────────────
# Encontre em: painel Supabase → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── WhatsApp da vendedora (Etapas 1 e 3) ────────────────────────────────
# Formato: código país + DDD + número, sem +, espaços ou hifens
# Exemplo Brasil: 5598999999999
VITE_WHATSAPP_VENDEDORA=5598999999999

# ─── URL do site em produção (Etapa 3 — Edge Function) ───────────────────
# Usado para back_urls do Mercado Pago. Sem barra no final.
VITE_SITE_URL=https://annabrowneria.vercel.app

# ─── Mercado Pago (Etapa 3 — APENAS na Edge Function do Supabase) ────────
# ⚠️  Esta variável NUNCA deve estar no frontend (.env do Vite)
# Configure-a no painel do Supabase → Edge Functions → Secrets
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# ─── Cloudinary (referência — URLs são inseridas manualmente no Supabase) ─
# Não é necessário no frontend. Use o painel do Cloudinary para upload.
# Formato de URL transformada:
# https://res.cloudinary.com/SEU_CLOUD_NAME/image/upload/w_600,h_400,c_fill,q_auto,f_auto/nome_da_imagem
